# ════════════════════════════════════════════════════════════
#  متغيّرات البيئة لتطبيق كلاود منيو (web/)
#  انسخ هذا الملف إلى .env.local للتطوير المحلي،
#  وأضِف نفس المفاتيح في Netlify → Site settings → Environment variables.
# ════════════════════════════════════════════════════════════

# Supabase — عامّة (تظهر في المتصفح، آمنة للواجهة)
NEXT_PUBLIC_SUPABASE_URL=https://wjqpsbpebpntpeinqccl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ضع_مفتاح_anon_هنا

# Moyasar — مفتاح النشر (publishable)
# للاختبار: pk_test_...  |  للإطلاق الفعلي: pk_live_...
NEXT_PUBLIC_MOYASAR_PK=pk_test_xxxxxxxxxxxxxxxx

# بريد المؤسس — يفتح صلاحية الوصول إلى /founder فقط لهذا البريد
FOUNDER_EMAIL=you@example.com
