# ════════════════════════════════════════════════════════════
#  متغيّرات البيئة لتطبيق كلاود منيو (web/)
#  انسخ هذا الملف إلى .env.local للتطوير المحلي،
#  وأضِف نفس المفاتيح في Netlify → Site settings → Environment variables.
# ════════════════════════════════════════════════════════════

# Supabase — عامّة (تظهر في المتصفح، آمنة للواجهة)
NEXT_PUBLIC_SUPABASE_URL=https://wjqpsbpebpntpeinqccl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ضع_مفتاح_anon_هنا

# Moyasar — مفتاح النشر (publishable)
# للاختبار: pk_test_...  |  للإطلاق الفعلي: pk_live_...
# ملاحظة: نفس الاسم مستخدم في web/src/components/billing/moyasar-form.tsx
NEXT_PUBLIC_MOYASAR_PK=pk_test_xxxxxxxxxxxxxxxx

# بريد المؤسس — يفتح صلاحية الوصول إلى /founder فقط لهذا البريد.
# يجب أن يطابق البريد المستخدم في قفل RLS (دالة is_founder في قاعدة البيانات).
FOUNDER_EMAIL=seeaf2013@gmail.com

# ════════════════════════════════════════════════════════════
# أسرار بوابات الدفع (Paylink / PayTabs / MyFatoorah / Moyasar SK)
# لا تُضاف هنا ولا في Netlify — تعيش حصراً في:
# Supabase → Edge Functions → Secrets (تستخدمها دالتا payments وmoyasar-webhook):
#   MOYASAR_SK, MOYASAR_WEBHOOK_SECRET,
#   PAYLINK_API_ID, PAYLINK_SECRET_KEY, (PAYLINK_BASE_URL اختياري)
#   PAYTABS_PROFILE_ID, PAYTABS_SERVER_KEY, (PAYTABS_BASE_URL اختياري)
#   MYFATOORAH_API_KEY, (MYFATOORAH_BASE_URL اختياري)
#   APP_BASE_URL (مثال: https://cloudsmenu.netlify.app)
# انظر docs/LAUNCH_CHECKLIST.md لخطوات الضبط كاملة.
# ════════════════════════════════════════════════════════════
